---
const experiences = [
  {
    role: "WordPress Developer",
    company: "Marketing Sweet",
    location: "Australia (Remote)",
    url: "https://marketingsweet.com.au/",
    period: "Jun 2025 - Present",
    logo: "/img/company/marketing-sweet.webp"
  },
  {
    role: "WordPress Developer",
    company: "Upwork Freelancer",
    location: "Freelance",
    url: "https://www.upwork.com/freelancers/~016b2a7c64e9b76d44",
    period: "Mar 2023 - May 2025",
    logo: "/img/company/upwork.png"
  },
  {
    role: "Senior WordPress Developer",
    company: "BluBird Interactive",
    location: "Bangladesh (Remote)",
    url: "https://blubirdinteractive.com/",
    period: "Jun 2024 - Dec 2024",
    logo: null
  },
  {
    role: "WordPress Developer",
    company: "Experience First",
    location: "USA (Remote)",
    url: "https://www.exp1.com/",
    period: "Apr 2020 - Mar 2024",
    logo: "/img/company/experience-first.webp"
  },
  {
    role: "Front End Engineer",
    company: "Jarvis Digital Ltd",
    location: "Dhaka, Bangladesh",
    url: "https://jarvis.ltd/",
    period: "Sept 2019 - Oct 2020",
    logo: "/img/company/jarvis-digital.webp"
  },
  {
    role: "Front End Engineer",
    company: "Tonix Media Agency",
    location: "Abu Dhabi, UAE (Remote)",
    url: null,
    period: "Feb 2019 - Aug 2019",
    logo: "/img/company/tonix.png"
  },
  {
    role: "Front End Developer",
    company: "Techtonix",
    location: "Dhaka, Bangladesh",
    url: null,
    period: "Feb 2017 - Feb 2019",
    logo: "/img/company/techtonix.png"
  }
];
---

<section id="experience" class="section-padding">
  <div class="container mx-auto max-w-4xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
      Work Experience
    </h2>
    <p class="text-zinc-400 text-center mb-12 max-w-2xl mx-auto">
      My professional journey
    </p>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-zinc-800"></div>

      <div class="space-y-12">
        {experiences.map((exp, index) => (
          <div 
            class={`relative flex flex-col md:flex-row gap-6 ${
              index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'
            }`}
          >
            <!-- Timeline dot -->
            <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-accent rounded-full -translate-x-1/2 transform md:translate-x-[-50%] mt-1.5 ring-4 ring-background"></div>
            
            <!-- Content -->
            <div class={`ml-12 md:ml-0 md:w-1/2 ${
              index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12 md:ml-auto'
            }`}>
              <a 
                href={exp.url || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class="block group"
              >
                {exp.logo && (
                  <img 
                    src={exp.logo}
                    alt={exp.company}
                    class={`w-12 h-12 rounded-lg object-cover mb-3 ${
                      index % 2 === 0 ? 'md:ml-auto' : ''
                    }`}
                  />
                )}
                <h3 class="text-lg font-semibold text-white group-hover:text-accent transition-colors">
                  {exp.role}
                </h3>
              </a>
              <p class="text-accent text-sm mb-1">{exp.company}</p>
              <p class="text-zinc-500 text-sm">{exp.location}</p>
              <p class="text-zinc-400 text-sm mt-2">{exp.period}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>