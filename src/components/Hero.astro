---
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-4 py-20">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Profile Image -->
      <div class="mb-8">
        <img 
          src="/img/img-profile.jpg" 
          alt="Nazmul Haque Sajol" 
          class="w-40 h-40 mx-auto rounded-full object-cover border-4 border-accent/30 shadow-lg"
        />
      </div>

      <!-- Name -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 tracking-tight">
        Nazmul Haque Sajol
      </h1>

      <!-- Title -->
      <p class="text-xl md:text-2xl text-accent font-medium mb-6">
        WordPress Developer
      </p>

      <!-- About Text -->
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        With over 8 years of experience crafting digital experiences, I specialize in custom WordPress themes, performance optimization, and building websites that convert. Let's bring your vision to life.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <a 
          href="https://www.upwork.com/o/profiles/users/~016b2a7c64e9b76d44"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-hover transition-all duration-300 shadow-lg shadow-accent/25 hover:shadow-accent/40"
        >
          Hire Me on Upwork
        </a>
        <a 
          href="https://www.linkedin.com/in/nhsajolbd"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3 border-2 border-zinc-700 text-zinc-300 font-semibold rounded-lg hover:border-accent hover:text-accent transition-all duration-300"
        >
          Connect on LinkedIn
        </a>
      </div>

      <!-- Social Links -->
      <div class="flex justify-center gap-6">
        <a 
          href="https://www.linkedin.com/in/nhsajolbd"
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 text-zinc-400 hover:text-accent transition-colors duration-300"
          aria-label="LinkedIn"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.104 10.252H3.333V9h2.994v8.685zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a 
          href="https://github.com/nhsajolbd"
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 text-zinc-400 hover:text-accent transition-colors duration-300"
          aria-label="GitHub"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a 
          href="mailto:nhsajolbd@gmail.com"
          class="p-3 text-zinc-400 hover:text-accent transition-colors duration-300"
          aria-label="Email"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </a>
        <a 
          href="/img/Nazmul Haque Sajol - Resume.pdf"
          target="_blank"
          class="p-3 text-zinc-400 hover:text-accent transition-colors duration-300"
          aria-label="Download Resume"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>