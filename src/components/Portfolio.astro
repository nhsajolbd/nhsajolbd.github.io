---

<section id="portfolio" class="section-padding bg-surface">
  <div class="container mx-auto max-w-6xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
      Portfolio
    </h2>
    <p class="text-zinc-400 text-center mb-12 max-w-2xl mx-auto">
      Some of the projects I've worked on
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, index) => (
        <a 
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-background rounded-xl overflow-hidden border border-zinc-800 hover:border-accent/50 hover:shadow-lg hover:shadow-accent/10 transition-all duration-300"
          style={`animation-delay: ${index * 50}ms`}
        >
          <div class="aspect-video overflow-hidden">
            <img 
              src={project.image}
              alt={project.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="text-lg font-semibold text-white group-hover:text-accent transition-colors">
                {project.name}
              </h3>
              <span class="text-xs px-2 py-1 bg-surface rounded-full text-zinc-400 shrink-0">
                {project.type}
              </span>
            </div>
            <p class="text-sm text-zinc-500 mt-1 truncate">
              {project.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>